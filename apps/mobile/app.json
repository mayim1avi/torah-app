{
  "expo": {
    "name": "Torah App",
    "slug": "torah-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "torahapp",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0a1f14",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.torahapp.mobile",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a1f14"
      },
      "package": "com.torahapp.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
