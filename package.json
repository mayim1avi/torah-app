{
  "name": "torah-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "concurrently -n api,web -c blue,green \"cd services/api && node --watch src/index.js\" \"pnpm --filter web dev\"",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "api": "turbo run dev --filter=api",
    "mobile": "turbo run dev --filter=mobile",
    "web": "turbo run dev --filter=web"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
